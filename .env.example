# Tale-AI 环境变量配置
# 复制此文件为 .env 并填入实际值

# ---- ChatLLM 对话模型 ----
TALE_CHAT_API_KEY=
TALE_CHAT_MODEL=
TALE_CHAT_URL=

# ---- PlanLLM 计划模型 ----
TALE_PLAN_API_KEY=
TALE_PLAN_MODEL=
TALE_PLAN_URL=

# ---- ToolLLM 工具调用模型 ----
TALE_TOOL_API_KEY=
TALE_TOOL_MODEL=
TALE_TOOL_URL=

# ---- 可选：Flask 调试模式 ----
# 设为 1 启用（仅开发环境），默认关闭
# FLASK_DEBUG=0
